generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transacao {
  id        String   @id @default(cuid())
  usuario   String   // JACSON | MANUELI
  tipo      String   // RECEITA | DESPESA
  valor     Decimal
  categoria String
  data      DateTime
  status    String   // PAGO | PENDENTE
  descricao String?
  createdAt DateTime @default(now())
}
