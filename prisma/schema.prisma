generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transacao {
  id        String   @id @default(cuid())
  usuario   String   // JACSON | MANUELI
  tipo      String   // RECEITA | DESPESA
  valor     Decimal
  categoria String
  data      DateTime
  status    String   // PAGO | PENDENTE
  isFixo    Boolean  @default(false)
  descricao String?
  createdAt DateTime @default(now())
}

model Meta {
  id            String   @id @default(cuid())
  titulo        String
  valorObjetivo Decimal
  valorAtual    Decimal  @default(0)
  descricao     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
